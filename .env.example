# ===== Operator secrets — never commit real values =====

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenSea API key (https://docs.opensea.io/reference/api-keys) — stays server-side only
OPENSEA_API_KEY=

# Bankr API key — used ONLY for deploying the x402 paid signals endpoint
BANKR_API_KEY=

# ===== Chain / RPC =====

# Public RPC works out of the box; use an Alchemy URL for production
# Alchemy: https://robinhood-mainnet.g.alchemy.com/v2/<key>
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# ===== Marketplace =====

# Treasury address that receives the 1% marketplace fee (Seaport consideration item)
# and x402 signal revenue. This is an ADDRESS only — no signing material anywhere.
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Marketplace fee in basis points (100 = 1%)
MARKETPLACE_FEE_BPS=100

# ===== Service URLs =====

API_URL=http://localhost:8787
MINIAPP_URL=https://your-miniapp.example.com

# apps/api listen port
API_PORT=8787

# Deployed Trader Cards contract (optional — enables /v1/metadata/trader-cards/:id)
TRADER_CARDS_ADDRESS=

# packages/signals dev harness
SIGNALS_PORT=8890
SIGNALS_PRICE_USDC=0.25
